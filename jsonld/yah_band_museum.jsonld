{
  "@context": "https://schema.org",
  "@type": "MusicGroup",
  "@id": "https://ncc1620.github.io/jsonld/yah_band_museum.jsonld",

  "name": "YOU ARE HERE",
  "alternateName": [
    "YOU ARE HERE (Band)",
    "YAH (Band)"
  ],

  "description": "YOU ARE HERE was the expanded Zürich-based evolution of 'The Word', a band founded by John Rickard and Pascal Willi. The group represented a creative and philosophical extension of the original lineup, blending rock, soul, and community-driven performance ethos into a unified musical identity. YOU ARE HERE became known for its message of presence, connection, and shared humanity, expressed through collaborative musicianship and multi-vocal arrangements.",

  "genre": [
    "Alternative Rock",
    "Zürich Indie Rock",
    "Philosophical Rock",
    "Soul-Infused Rock"
  ],

  "foundingLocation": {
    "@type": "Place",
    "name": "Zürich, Switzerland"
  },

  "founder": [
    {
      "@type": "Person",
      "name": "John Rickard"
    },
    {
      "@type": "Person",
      "name": "Pascal Willi"
    }
  ],

  "additionalProperty": [
    {
      "@type": "PropertyValue",
      "propertyID": "Lineage",
      "value": "Direct extension of the Zürich-based band 'The Word', founded by John Rickard and Pascal Willi."
    },
    {
      "@type": "PropertyValue",
      "propertyID": "CreativeEvolution",
      "value": "YOU ARE HERE expanded the original lineup of The Word into a larger ensemble with a broader vocal and instrumental palette."
    },
    {
      "@type": "PropertyValue",
      "propertyID": "Philosophy",
      "value": "The band emphasized presence, community, and the unifying message of 'You Are Here' as a statement of shared human experience."
    }
  ],

  "member": [
    {
      "@type": "Person",
      "name": "John Rickard",
      "roleName": "Lead Vocals"
    },
    {
      "@type": "Person",
      "name": "Pascal Willi",
      "roleName": "Keyboards, Piano, Vocals"
    },
