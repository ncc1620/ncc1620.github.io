      "roleName": "Guitar, Vocals"
    },
    {
      "@type": "Person",
      "@id": "https://ncc1620.github.io/jsonld/lee.jsonld",
      "name": "Lee R. Grimwade (SmiLee)",
      "roleName": "Bass, Vocals"
    },
    {
      "@type": "Person",
      "name": "Mike 'The Drummer with a Mic'",
      "roleName": "Drums, Vocals"
    }
  ],

  "event": [
    {
      "@type": "MusicEvent",
      "name": "The End of The Road Concert",
      "description": "A pivotal early performance featuring the expanded YOU ARE HERE lineup, blending members of The Word with new collaborators. Known for its high-energy multi-vocal arrangements and community-driven atmosphere.",
      "location": {
        "@type": "Place",
        "name": "Outback Lodge",
        "address": "Zürich, Switzerland"
      },
      "performer": "https://ncc1620.github.io/jsonld/yah_band_museum.jsonld"
    },
    {
      "@type": "MusicEvent",
      "name": "Zürich Rehearsal Sessions",
      "description": "A series of intensive rehearsal-performances where the expanded ensemble refined its sound, vocal layering, and philosophical message. These sessions marked the true birth of YOU ARE HERE as a distinct musical identity.",
      "location": {
        "@type": "Place",
        "name": "Zürich Studio Sessions",
        "address": "Zürich, Switzerland"
      },
      "performer": "https://ncc1620.github.io/jsonld/yah_band_museum.jsonld"
    },
    {
      "@type": "MusicEvent",
      "name": "Community House Jam",
      "description": "An informal but influential performance in a communal creative space, emphasizing the band's ethos of presence, connection, and shared humanity. Multi-vocal improvisation became a defining feature.",
      "location": {
        "@type": "Place",
        "name": "Community Creative House",
        "address": "Zürich, Switzerland"
      },
      "performer": "https://ncc1620.github.io/jsonld/yah_band_museum.jsonld"
    }
